# PolyGuard Backend Configuration

# Server
PORT=3000
NODE_ENV=development

# Polymarket CLOB API
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Builder Code & Signing
BUILDER_CODE=your_builder_code_here
BUILDER_SECRET_KEY=your_secret_key_here

# SIWE (Sign-In-With-Ethereum)
SIWE_DOMAIN=localhost
SIWE_URI=http://localhost:3000

# Extension Communication
EXTENSION_ORIGIN=chrome-extension://your_extension_id_here

# Paper Trading Mode (set to false for real trades - not recommended)
PAPER_TRADING=true

# Logging
LOG_LEVEL=info
