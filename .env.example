# PolyGuard Backend Environment Variables

# Server Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Polymarket CLOB API
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Polymarket Builder Code (for real order signing)
BUILDER_CODE=your_builder_code_here
BUILDER_SECRET_KEY=your_secret_key_here
BUILDER_PASSPHRASE=your_passphrase_here

# Supabase (PostgreSQL Database)
POSTGRES_URL=postgresql://postgres:password@db.supabase.co:5432/postgres

# Supabase API
SUPABASE_URL=https://jetbtxghxgkuagndsfen.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# SIWE (Sign-In-With-Ethereum)
SIWE_DOMAIN=localhost
SIWE_URI=http://localhost:3000

# Chrome Extension Origin (for CORS)
EXTENSION_ORIGIN=chrome-extension://your_extension_id

# Paper Trading Mode (default true, no real trades executed)
PAPER_TRADING=true

# Additional APIs
POLYMARKET_API=your_api_key_here
POLYMARKET_SECRET=your_secret_here

# Optional: Discord Alerts
DISCORD_WEBHOOK_TRADES=

# Optional: Finnhub (for economic calendar)
FINNHUB_API_KEY=

# Optional: Polygon.io (market data)
POLYGON_IO_API_KEY=
